\mode<presentation>

% color
\definecolor{bfeld@green}{RGB}{0,117,86}
\definecolor{bfeld@blue}{RGB}{70,80,110}
\definecolor{bfeld@grey}{RGB}{124, 131, 136}
\definecolor{lgr}{RGB}{200,200,200}
\definecolor{bfeld@red}{RGB}{180,20,20}
\definecolor{bfeld@lightgrey}{RGB}{242,242,242}
\setbeamercolor*{title}{fg=bfeld@blue}
\setbeamercolor*{subtitle}{fg=bfeld@grey}
\setbeamercolor*{author}{fg=black}
\setbeamercolor*{date}{fg=bfeld@green}
\setbeamercolor*{institute}{fg=bfeld@green}
\setbeamercolor*{frametitle}{fg=bfeld@blue}
\setbeamercolor*{framesubtitle}{fg=bfeld@grey}
\setbeamercolor*{item}{fg=bfeld@blue}
\setbeamercolor*{subitem}{fg=bfeld@grey}
\setbeamercolor*{normal text}{fg=black,bg=white}
\setbeamercolor*{alerted text}{fg=bfeld@red}
\setbeamercolor*{example text}{fg=black}
\setbeamercolor*{structure}{fg=bfeld@grey}
\setbeamercolor*{author in head/foot}{fg=bfeld@grey}
\setbeamercolor*{date in head/foot}{fg=bfeld@grey}
\setbeamercolor*{block body}{bg= lgr}
\setbeamercolor*{block title}{fg=white, bg = bfeld@grey}
\setbeamercolor{button}{bg=bfeld@green, fg=white}

% font
\setbeamerfont{title}{size=\large}
\setbeamerfont{subtitle}{size=\normalsize}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{institute}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{alerted text}{series=\bfseries}
\setbeamerfont{frametitle}{size=\large}

% items
\setbeamertemplate{sections/subsections in toc}[square]
\setbeamertemplate{itemize item}[square]
\setbeamertemplate{itemize subitem}[circle]
\setbeamertemplate{itemize subsubitem}[circle]

% margins and outer
\setbeamersize{text margin left = 10mm, text margin right = 10mm}
\setbeamertemplate{navigation symbols}{}

% frame title
\setbeamertemplate{frametitle}[default][center]
\addtobeamertemplate{frametitle}{\vspace*{0.6cm}}{\vspace*{0.3cm}}
\makeatletter
\patchcmd{\endbeamer@frameslide}{
  \ifx\beamer@frametitle\@empty}{\iffalse}{}{\errmessage{failed to patch}
}
\makeatother
\setbeamertemplate{frametitle continuation}{}

% footer
\defbeamertemplate*{footline}{bfeld}
{\leavevmode%
\hskip 0.05\linewidth
  \hbox{%
  \begin{beamercolorbox}[wd=.75\linewidth,ht=2.25ex,left]{author in head/foot}%
    \usebeamerfont{author in head/foot}%
    \hspace*{3ex}\insertauthor~~$|$~~\insertshorttitle
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.25\paperwidth,ht=2.25ex,right]{date in head/foot}%
    \usebeamerfont{date in head/foot}
    \insertframenumber{} / \inserttotalframenumber\hspace*{3ex}
  \end{beamercolorbox}
  }%
  \hskip 0.05\linewidth
  \vskip 10pt%
}

% background
\usebackgroundtemplate{
  \vbox{ 
    \vspace{10pt}
    \begin{tabular}{p{0.01\paperwidth} l} 
      & \hyperlink{appendix}{\includegraphics[width=2.25cm]{theme/logo.png}} 
  \end{tabular}
  }
}

% title page
\makeatletter
\setbeamertemplate{title page}{
  \vbox{}
  \vfill
  \begin{centering}
    \begin{beamercolorbox}[sep=8pt,center]{title}
      \usebeamerfont{title}\inserttitle\par%
    \end{beamercolorbox}
    \vskip0.1em
    \begin{beamercolorbox}[sep=8pt,center]{subtitle}
      \ifx\insertsubtitle\@empty\else
        {\usebeamerfont{subtitle}\insertsubtitle\par}%
      \fi
    \end{beamercolorbox}
    \vskip1em
    \begin{beamercolorbox}[sep=8pt,center]{author}
      \usebeamerfont{author}\insertauthor
    \end{beamercolorbox}
    \vskip1em
    \begin{beamercolorbox}[sep=8pt,center]{institute}
      \usebeamerfont{institute}\insertinstitute
    \end{beamercolorbox}
    \vskip0.1em
    \begin{beamercolorbox}[sep=8pt,center]{date}
      \usebeamerfont{date}\insertdate
    \end{beamercolorbox}
  \end{centering}
  \vfill
}
\makeatother

\mode<all>